# Dev: leave empty to use Vite proxy (see vite.config.js → VITE_DEV_API_PROXY_TARGET).
# Production build: set full API origin, e.g. https://your-api-xxxxx.run.app
VITE_API_BASE_URL=

# Vite dev + vite preview proxy target for /api and /health (must match backend PORT).
# Default is http://127.0.0.1:3000. If your API runs elsewhere, e.g.:
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3001
